APP_NAME=Alvora
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=43200
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

TEST_MODE_PASSWORD=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Почта: Yandex Cloud Postbox (замените placeholder на реальные ключи) ---
# Пока DKIM не Verified — письма не уйдут; для теста укажите свой ящик в NOTIFICATION_EMAIL_OVERRIDE.
MAIL_MAILER=smtp
# Для порта 587 (STARTTLS) scheme не задаём или smtp. smtps — только для порта 465 (SSL).
# НЕ пишите tls — Laravel принимает только smtp / smtps.
# MAIL_SCHEME=
MAIL_HOST=postbox.cloud.yandex.net
MAIL_PORT=587
MAIL_USERNAME=aje_placeholder_postbox_key_id
MAIL_PASSWORD=placeholder_postbox_secret_replace_me
MAIL_FROM_ADDRESS=noreply@alvoraplace.ru
MAIL_FROM_NAME="${APP_NAME}"

# Все уведомления (колокольчик) дублируются на email, если у пользователя есть почта.
NOTIFICATION_EMAIL_ENABLED=true
# Пока Postbox не настроен — все письма на один ящик (удалите строку после запуска Postbox):
NOTIFICATION_EMAIL_OVERRIDE=you@example.com
NOTIFICATION_EMAIL_LOG_ON_FAILURE=true

MARKETPLACE_SUPPORT_EMAIL=support@alvoraplace.ru

# Отключение отдельных типов писем (true/false). Пример: не слать «заказ в ПВЗ»:
# NOTIFY_EMAIL_ORDER_DELIVERED=false
NOTIFY_EMAIL_GENERAL=true
NOTIFY_EMAIL_AUTH_LOGIN_OTP=true
NOTIFY_EMAIL_AUTH_LOGIN_SMS=true
NOTIFY_EMAIL_AUTH_PASSWORD_RESET=true
NOTIFY_EMAIL_AUTH_PROFILE_PHONE=true
NOTIFY_EMAIL_SECURITY=true
NOTIFY_EMAIL_ACCOUNT=true
NOTIFY_EMAIL_ORDER_CREATED=true
NOTIFY_EMAIL_ORDER_PAID=true
NOTIFY_EMAIL_ORDER_IN_TRANSIT=true
NOTIFY_EMAIL_ORDER_DELIVERED=true
NOTIFY_EMAIL_ORDER_ISSUED=true
NOTIFY_EMAIL_ORDER_CANCELED=true
NOTIFY_EMAIL_ORDER_REFUSED=true
NOTIFY_EMAIL_ORDER_REFUNDED=true
NOTIFY_EMAIL_ORDER_REFUSAL_CODE=true
NOTIFY_EMAIL_PVZ_ADMIN=true
NOTIFY_EMAIL_PVZ_OPERATOR=true
NOTIFY_EMAIL_SELLER_MODERATION=true

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
